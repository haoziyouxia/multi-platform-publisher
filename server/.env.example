# 多平台内容分发工具 - 环境配置
# 复制本文件为 .env 并修改对应值

# 服务端口
PORT=3000

# 数据库路径
DB_PATH=./data/app.db

# 文件上传目录
UPLOAD_DIR=./uploads

# CORS 允许的前端地址
CORS_ORIGIN=http://localhost:5173

# 浏览器自动化配置
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000
MAX_CONCURRENT_PUBLISH=3

# 热榜缓存（毫秒，默认 30 分钟）
HOTLIST_CACHE_MS=1800000

# AI 二创（OpenAI 兼容接口，可换 baseURL/model 接其他厂商）
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=120000

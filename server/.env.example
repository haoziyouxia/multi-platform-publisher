# 多平台内容分发工具 - 环境配置
# 复制本文件为 .env 并修改对应值

# 服务端口
PORT=3000

# 数据库路径
DB_PATH=./data/app.db

# 文件上传目录
UPLOAD_DIR=./uploads

# CORS 允许的前端地址
CORS_ORIGIN=http://localhost:5173

# 浏览器自动化配置
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000
MAX_CONCURRENT_PUBLISH=3

# 热榜缓存（毫秒，默认 30 分钟）
HOTLIST_CACHE_MS=1800000

# AI 二创（OpenAI 兼容接口，可换 baseURL/model 接其他厂商）
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
# 模型较慢时建议 180000～300000
AI_TIMEOUT_MS=180000

# 微信公众号草稿细节
# 作者字段平台限制 ≤ 8 字
WECHAT_AUTHOR=咸鱼翻炒炸
# 是否尝试声明原创（账号无原创权限时会跳过/失败但不阻断草稿）
WECHAT_DECLARE_ORIGINAL=true
# 默认只存草稿；true 时额外尝试点击「发表」
WECHAT_TRY_PUBLISH=false

# 搜索抓取规模（垂直赛道搜文）
SEARCH_QUERY_LIMIT=6
SEARCH_PER_ENGINE=12
SEARCH_RAW_CAP=40
SEARCH_RESULT_LIMIT=20
SEARCH_EXTRACT_COUNT=8
SEARCH_LIST_LIMIT=40
